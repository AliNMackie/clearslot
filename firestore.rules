rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // OPTION A: All data access routes through the FastAPI backend
    // which uses the Firebase Admin SDK (bypasses these rules).
    // Client-side reads/writes are fully locked down.
    // ============================================================

    // Public club branding is the ONLY client-readable path.
    // Landing pages (/clubs/:slug) need this to render without auth.
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if false;

      // All subcollections are locked — served via backend API
      match /{subcollection=**} {
        allow read, write: if false;
      }
    }

    // Bookings: backend-only via Admin SDK
    match /bookings/{bookingId} {
      allow read, write: if false;
    }

    // Truth Machine Audit Logs: backend-only, immutable
    match /booking_audit_logs/{logId} {
      allow read, write: if false;
    }

    // Weather cache: backend-only
    match /weather_cache/{document=**} {
      allow read, write: if false;
    }

    // User profiles: backend-only
    match /users/{userId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
